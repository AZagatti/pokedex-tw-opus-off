{
  "name": "pokedex-tw-opus-off",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "oxlint --config oxlint.config.ts",
    "lint:fix": "oxlint --config oxlint.config.ts --fix",
    "format": "oxfmt --config oxfmt.config.ts .",
    "format:check": "oxfmt --config oxfmt.config.ts --check .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "lucide-svelte": "^1.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/svelte": "^5.4.2",
    "@vitest/browser": "^4.1.10",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "ultracite": "7.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "lefthook@2.1.10": true
  }
}
